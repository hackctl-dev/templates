{
  "$schema": "https://hackctl.dev/schemas/hackctl.config.v1.json",
  "name": "my-app",
  "template": "next-supabase",
  "services": [
    {
      "name": "app",
      "cwd": ".",
      "run": "npm run dev",
      "port": 3000
    }
  ],
  "share": {
    "defaultService": "app",
    "defaultPort": 3000
  },
  "deploy": {
    "runtime": "pm2",
    "mode": "dev"
  }
}
